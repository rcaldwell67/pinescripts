//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Adaptive Pullback Momentum v3.1
// 1h BTC-USD  |  Longs Only
// THESIS
//   Most breakout strategies enter *after* the move is mature.  This strategy
//   enters during brief pullbacks to a key moving average while the broader
//   trend is intact, giving tighter natural stops and a higher-quality R:R.
//
// ENTRY LOGIC (v3.1 — longs only)
//   Long  : close > EMA200  |  EMA21 > EMA50  |  EMA21 slope rising (3-bar)
//            prev-bar low tagged EMA21, current bar recovers above EMA21 (bullish body)
//            + RSI 42–72  |  Volume ≥ 1.5× VolSMA  |  ADX > 35  |  no panic
//            + body ≥ 0.20×ATR  |  ATR floor 0.30% of price
//
// EXIT LOGIC
//   → Hard stop  : entry − ATR_eff × 1.5
//   → Hard TP    : entry + ATR_eff × 1.5  (1:1 R:R — sweep peak)
//   → Trail      : activates once price moves ATR×2.5 in favour,
//                  then trails ATR×0.5 from best price
//   → Sizing     : 1 % of equity risked per trade
//
// v3.1 CHANGES vs v3.0  (BTC-USD 1h max-history sweep, 7 phases)
//   Longs only   : shorts disabled (33% WR on 1h; longs 83% WR)
//   ADX threshold: 25 → 35     (strong-trend filter; dramatically raises WR)
//   PB tolerance : 0.15% → 0.10%  (tighter pullback = higher-quality entries)
//   TP multiplier: 2.0× → 1.5×   (sweep peak at 1h; most TP exits at 1.5×)
//   Trail activate: 1.5× → 2.5×  (lets 1h winners run before trailing)
//   Trail distance: 0.8× → 0.5×  (snappier lock-in once activated)
//   Volume mult  : 1.0× → 1.5×   (filters low-conviction pullbacks)
//   Min body     : 0.15× → 0.20× (rejects weak-bodied candles)
//   RSI max long : 68 → 72       (allows entries up to near-overbought)
//   EMA slope    : added — EMA21 must be rising over 3 bars (no flat entries)
//   ATR floor    : added — 0.30% of price (kills commission drag on tiny moves)
// ─────────────────────────────────────────────────────────────────────────────

strategy(
    title             = "Adaptive Pullback Momentum v3.1",
    shorttitle        = "APM v3.1",
    overlay           = true,
    pyramiding        = 0,
    initial_capital   = 10000,
    default_qty_type  = strategy.cash,
    default_qty_value = 10000,        // overridden by risk-based sizing below
    commission_type   = strategy.commission.percent,
    commission_value  = 0.06,
    slippage          = 1)

// ── Inputs ───────────────────────────────────────────────────────────────────
var G_TREND = "Trend Filters"
i_ema_fast   = input.int  (21,   "EMA Fast",            group=G_TREND, minval=5)
i_ema_mid    = input.int  (50,   "EMA Mid",             group=G_TREND, minval=10)
i_ema_slow   = input.int  (200,  "EMA Slow",            group=G_TREND, minval=50)
i_adx_thresh = input.int  (35,   "ADX threshold",       group=G_TREND, minval=5,  maxval=60)
i_adx_len    = input.int  (14,   "ADX / DI length",     group=G_TREND, minval=5)
i_pb_pct     = input.float(0.10, "Pullback tolerance (%)", group=G_TREND, minval=0.05, maxval=3.0, step=0.05,
                 tooltip="How close the prev bar's low/high must come to EMA-fast to count as a pullback")
i_ema_slope  = input.bool (true, "EMA slope filter (3-bar)", group=G_TREND,
                 tooltip="Require EMA-fast to be rising (longs) / falling (shorts) over the last 3 bars")

var G_MOM = "Momentum & Volume"
i_rsi_len    = input.int  (14,   "RSI length",            group=G_MOM, minval=3)
i_rsi_lo_l   = input.int  (42,   "RSI min – Long",        group=G_MOM, minval=10, maxval=70)
i_rsi_hi_l   = input.int  (72,   "RSI max – Long",        group=G_MOM, minval=50, maxval=90)
i_rsi_lo_s   = input.int  (32,   "RSI min – Short",       group=G_MOM, minval=10, maxval=50)
i_rsi_hi_s   = input.int  (58,   "RSI max – Short",       group=G_MOM, minval=40, maxval=80)
i_vol_len    = input.int  (20,   "Volume SMA length",     group=G_MOM, minval=5)
i_vol_mult   = input.float(1.5,  "Volume multiplier",     group=G_MOM, minval=0.3, maxval=5.0, step=0.1)
i_min_body   = input.float(0.20, "Min body (×ATR)",        group=G_MOM, minval=0.0, maxval=2.0, step=0.05,
                 tooltip="Entry bar body (|close-open|/ATR) must exceed this — filters doji / indecision candles")

var G_VOL = "Volatility"
i_atr_len    = input.int  (14,   "ATR length",            group=G_VOL, minval=3)
i_panic_mult = input.float(1.5,  "Panic suppression mult",group=G_VOL, minval=1.0, step=0.1,
                 tooltip="ATR14 > ATR-60SMA × this value → skip new entries")
i_atr_floor  = input.float(0.30, "ATR floor (% of price)",group=G_VOL, minval=0.0, maxval=2.0, step=0.05,
                 tooltip="ATR is floored at this % of price before stop sizing — kills commission drag on tiny-ATR entries")

var G_RISK = "Risk Management"
i_sl_mult    = input.float(1.5,  "Stop loss ATR mult",    group=G_RISK, minval=0.3, step=0.1)
i_tp_mult    = input.float(1.5,  "Take profit ATR mult",  group=G_RISK, minval=0.5, step=0.1)
i_tr_act     = input.float(2.5,  "Trail activate ATR mult",group=G_RISK,minval=0.3, step=0.1,
                 tooltip="Trailing stop kicks in once price moves this many ATRs in your favour")
i_tr_dist    = input.float(0.5,  "Trail distance ATR mult",group=G_RISK,minval=0.2, step=0.1,
                 tooltip="Once active, trail stays this many ATRs below/above the best price")
i_risk_pct   = input.float(1.0,  "Equity risked per trade (%)",group=G_RISK,minval=0.1,maxval=20,step=0.1)

var G_DISP = "Display"
i_longs      = input.bool(true,  "Trade Longs",   group=G_DISP)
i_shorts     = input.bool(false, "Trade Shorts",  group=G_DISP)
i_show_emas  = input.bool(true,  "Show EMAs",     group=G_DISP)
i_show_dash  = input.bool(true,  "Show Dashboard",group=G_DISP)
i_dash_pos   = input.string("Top Right", "Dashboard position", group=G_DISP,
                 options=["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right","Middle Left"])

// ── Indicators ────────────────────────────────────────────────────────────────
ema_fast      = ta.ema(close, i_ema_fast)
ema_mid       = ta.ema(close, i_ema_mid)
ema_slow      = ta.ema(close, i_ema_slow)
ema_fast_sl   = ema_fast - ema_fast[3]   // 3-bar EMA slope (>0 rising, <0 falling)
rsi           = ta.rsi(close, i_rsi_len)
atr           = ta.atr(i_atr_len)
atr_bl        = ta.sma(atr, 60)               // 60-bar ATR baseline
atr_eff       = math.max(atr, close * i_atr_floor / 100.0)  // floored ATR for sizing
vol_ma        = ta.sma(volume, i_vol_len)

[di_plus, di_minus, adx] = ta.dmi(i_adx_len, i_adx_len)

// ── Regime guards ─────────────────────────────────────────────────────────────
is_trending = adx > i_adx_thresh
is_panic    = atr > atr_bl * i_panic_mult

// ── Pullback-to-EMA trigger ───────────────────────────────────────────────────
// Long : prev bar's low came within pullback tolerance of EMA-fast FROM ABOVE,
//        current bar closes ABOVE EMA-fast with a bullish body (close > open)
pb_tol_up  = ema_fast[1] * (1.0 + i_pb_pct / 100.0)
body_size  = math.abs(close - open) / atr
long_pb    = low[1] <= pb_tol_up and close > ema_fast and close > open and body_size >= i_min_body

// Short: prev bar's high came within pullback tolerance of EMA-fast FROM BELOW,
//        current bar closes BELOW EMA-fast with a bearish body (close < open)
pb_tol_dn  = ema_fast[1] * (1.0 - i_pb_pct / 100.0)
short_pb   = high[1] >= pb_tol_dn and close < ema_fast and close < open and body_size >= i_min_body

// ── Full entry conditions ─────────────────────────────────────────────────────
no_pos     = strategy.position_size == 0.0
stop_dist  = atr_eff * i_sl_mult

long_ok  = i_longs  and no_pos and not is_panic and is_trending and
     long_pb and
     close      > ema_slow and                              // macro bullish
     ema_fast   > ema_mid  and                              // medium-term structure up
     (not i_ema_slope or ema_fast_sl > 0) and              // EMA slope rising
     rsi       >= i_rsi_lo_l and rsi <= i_rsi_hi_l and
     volume    >= vol_ma * i_vol_mult

short_ok = i_shorts and no_pos and not is_panic and is_trending and
     short_pb and
     close      < ema_slow and                              // macro bearish
     ema_fast   < ema_mid  and                              // medium-term structure down
     (not i_ema_slope or ema_fast_sl < 0) and              // EMA slope falling
     rsi       >= i_rsi_lo_s and rsi <= i_rsi_hi_s and
     volume    >= vol_ma * i_vol_mult

// ── State for manual trailing stop management ─────────────────────────────────
var float sl_price    = na
var float tp_price    = na
var float best_price  = na
var float entry_p     = na
var bool  trail_active = false

// ── Entries ───────────────────────────────────────────────────────────────────
if long_ok
    qty            = strategy.equity * i_risk_pct / 100.0 / stop_dist
    sl_price      := close - stop_dist
    tp_price      := close + atr_eff * i_tp_mult
    best_price    := close
    trail_active  := false
    strategy.entry("Long", strategy.long, qty=qty)
    _sd    = stop_dist
    _tp    = close + atr_eff * i_tp_mult
    _rr    = i_tp_mult / i_sl_mult
    _risk  = strategy.equity * i_risk_pct / 100.0
    _qty   = strategy.equity * i_risk_pct / 100.0 / stop_dist
    _atrp  = atr / close * 100
    _atrfl = atr_eff >= close * i_atr_floor / 100.0 ? "OK" : "FAIL"
    _vol   = volume / vol_ma
    _body  = math.abs(close - open) / atr
    _slope = ema_fast > ema_fast[3] ? "UP" : "DOWN"
    alert(
        "APM v3.1 | LONG ENTRY | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
        "Entry   : " + str.tostring(close, "#.##") + "  |  Equity: $" + str.tostring(math.round(strategy.equity, 2), "#.##") + "\n" +
        "Stop    : " + str.tostring(math.round(close - _sd, 2), "#.##") + "  (-" + str.tostring(math.round(_sd, 2), "#.##") + " = ATR x" + str.tostring(i_sl_mult) + ")\n" +
        "Target  : " + str.tostring(math.round(_tp, 2), "#.##") + "  (+" + str.tostring(math.round(atr_eff * i_tp_mult, 2), "#.##") + " = ATR x" + str.tostring(i_tp_mult) + ")\n" +
        "R:R     : 1:" + str.tostring(math.round(_rr, 2), "#.##") + "  |  Risk: $" + str.tostring(math.round(_risk, 2), "#.##") + " (" + str.tostring(i_risk_pct) + "%)\n" +
        "Qty     : " + str.tostring(math.round(_qty, 4), "#.####") + "\n" +
        "ATR     : " + str.tostring(math.round(atr, 2), "#.##") + " (" + str.tostring(math.round(_atrp, 3), "#.###") + "% of price)  |  Floor: " + _atrfl + "\n" +
        "RSI     : " + str.tostring(math.round(rsi, 2), "#.##") + " [" + str.tostring(i_rsi_lo_l) + "-" + str.tostring(i_rsi_hi_l) + "]  |  Dir: " + (rsi > rsi[1] ? "Rising" : "Falling") + "\n" +
        "ADX     : " + str.tostring(math.round(adx, 2), "#.##") + "  DI+: " + str.tostring(math.round(di_plus, 2), "#.##") + "  DI-: " + str.tostring(math.round(di_minus, 2), "#.##") + "  [min " + str.tostring(i_adx_thresh) + "]\n" +
        "Vol/MA  : " + str.tostring(math.round(_vol, 2), "#.##") + "x  [min " + str.tostring(i_vol_mult) + "x]\n" +
        "Body    : " + str.tostring(math.round(_body, 3), "#.###") + "x ATR  [min " + str.tostring(i_min_body) + "x]\n" +
        "EMA" + str.tostring(i_ema_fast) + "/" + str.tostring(i_ema_mid) + "/" + str.tostring(i_ema_slow) + ": " + str.tostring(math.round(ema_fast, 2), "#.##") + "/" + str.tostring(math.round(ema_mid, 2), "#.##") + "/" + str.tostring(math.round(ema_slow, 2), "#.##") + "  Stack: BULL  Slope: " + _slope + "\n" +
        "Trail on: +" + str.tostring(math.round(atr_eff * i_tr_act, 2), "#.##") + " (ATR x" + str.tostring(i_tr_act) + ")  Dist: " + str.tostring(math.round(atr_eff * i_tr_dist, 2), "#.##") + " (ATR x" + str.tostring(i_tr_dist) + ")\n" +
        "Time    : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
        alert.freq_once_per_bar_close)

if short_ok
    qty            = strategy.equity * i_risk_pct / 100.0 / stop_dist
    sl_price      := close + stop_dist
    tp_price      := close - atr_eff * i_tp_mult
    best_price    := close
    trail_active  := false
    strategy.entry("Short", strategy.short, qty=qty)
    _sd    = stop_dist
    _tp    = close - atr_eff * i_tp_mult
    _rr    = i_tp_mult / i_sl_mult
    _risk  = strategy.equity * i_risk_pct / 100.0
    _qty   = strategy.equity * i_risk_pct / 100.0 / stop_dist
    _atrp  = atr / close * 100
    _atrfl = atr_eff >= close * i_atr_floor / 100.0 ? "OK" : "FAIL"
    _vol   = volume / vol_ma
    _body  = math.abs(close - open) / atr
    _slope = ema_fast < ema_fast[3] ? "DOWN" : "UP"
    alert(
        "APM v3.1 | SHORT ENTRY | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
        "Entry   : " + str.tostring(close, "#.##") + "  |  Equity: $" + str.tostring(math.round(strategy.equity, 2), "#.##") + "\n" +
        "Stop    : " + str.tostring(math.round(close + _sd, 2), "#.##") + "  (+" + str.tostring(math.round(_sd, 2), "#.##") + " = ATR x" + str.tostring(i_sl_mult) + ")\n" +
        "Target  : " + str.tostring(math.round(_tp, 2), "#.##") + "  (-" + str.tostring(math.round(atr_eff * i_tp_mult, 2), "#.##") + " = ATR x" + str.tostring(i_tp_mult) + ")\n" +
        "R:R     : 1:" + str.tostring(math.round(_rr, 2), "#.##") + "  |  Risk: $" + str.tostring(math.round(_risk, 2), "#.##") + " (" + str.tostring(i_risk_pct) + "%)\n" +
        "Qty     : " + str.tostring(math.round(_qty, 4), "#.####") + "\n" +
        "ATR     : " + str.tostring(math.round(atr, 2), "#.##") + " (" + str.tostring(math.round(_atrp, 3), "#.###") + "% of price)  |  Floor: " + _atrfl + "\n" +
        "RSI     : " + str.tostring(math.round(rsi, 2), "#.##") + " [" + str.tostring(i_rsi_lo_s) + "-" + str.tostring(i_rsi_hi_s) + "]  |  Dir: " + (rsi < rsi[1] ? "Falling" : "Rising") + "\n" +
        "ADX     : " + str.tostring(math.round(adx, 2), "#.##") + "  DI+: " + str.tostring(math.round(di_plus, 2), "#.##") + "  DI-: " + str.tostring(math.round(di_minus, 2), "#.##") + "  [min " + str.tostring(i_adx_thresh) + "]\n" +
        "Vol/MA  : " + str.tostring(math.round(_vol, 2), "#.##") + "x  [min " + str.tostring(i_vol_mult) + "x]\n" +
        "Body    : " + str.tostring(math.round(_body, 3), "#.###") + "x ATR  [min " + str.tostring(i_min_body) + "x]\n" +
        "EMA" + str.tostring(i_ema_fast) + "/" + str.tostring(i_ema_mid) + "/" + str.tostring(i_ema_slow) + ": " + str.tostring(math.round(ema_fast, 2), "#.##") + "/" + str.tostring(math.round(ema_mid, 2), "#.##") + "/" + str.tostring(math.round(ema_slow, 2), "#.##") + "  Stack: BEAR  Slope: " + _slope + "\n" +
        "Trail on: -" + str.tostring(math.round(atr_eff * i_tr_act, 2), "#.##") + " (ATR x" + str.tostring(i_tr_act) + ")  Dist: " + str.tostring(math.round(atr_eff * i_tr_dist, 2), "#.##") + " (ATR x" + str.tostring(i_tr_dist) + ")\n" +
        "Time    : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
        alert.freq_once_per_bar_close)

// ── Trailing stop update (runs every bar while in trade) ──────────────────────
if strategy.position_size > 0.0          // long
    best_price := math.max(best_price, high)
    entry_p    := strategy.position_avg_price
    if best_price >= entry_p + atr * i_tr_act
        trail_sl_new = best_price - atr * i_tr_dist
        trail_sl_new := math.max(sl_price, trail_sl_new)
        if not trail_active
            trail_active := true
            _runup = best_price - entry_p
            alert(
                "APM v3.1 | TRAIL STOP ACTIVATED | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
                "Direction : LONG\n" +
                "Best price: " + str.tostring(math.round(best_price, 2), "#.##") + "  |  Entry: " + str.tostring(math.round(entry_p, 2), "#.##") + "\n" +
                "Trail SL  : " + str.tostring(math.round(trail_sl_new, 2), "#.##") + "  (best - ATR x" + str.tostring(i_tr_dist) + " = -" + str.tostring(math.round(atr * i_tr_dist, 2), "#.##") + ")\n" +
                "Prev SL   : " + str.tostring(math.round(sl_price, 2), "#.##") + "  |  Target: " + str.tostring(math.round(tp_price, 2), "#.##") + "\n" +
                "Runup     : +" + str.tostring(math.round(_runup, 2), "#.##") + " (" + str.tostring(math.round(_runup / entry_p * 100, 2), "#.##") + "%)\n" +
                "Time      : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
                alert.freq_once_per_bar_close)
        sl_price := trail_sl_new
    strategy.exit("Long Exit", "Long", stop=sl_price, limit=tp_price)

if strategy.position_size < 0.0          // short
    best_price := math.min(best_price, low)
    entry_p    := strategy.position_avg_price
    if best_price <= entry_p - atr * i_tr_act
        trail_sl_new = best_price + atr * i_tr_dist
        trail_sl_new := math.min(sl_price, trail_sl_new)
        if not trail_active
            trail_active := true
            _runup = entry_p - best_price
            alert(
                "APM v3.1 | TRAIL STOP ACTIVATED | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
                "Direction : SHORT\n" +
                "Best price: " + str.tostring(math.round(best_price, 2), "#.##") + "  |  Entry: " + str.tostring(math.round(entry_p, 2), "#.##") + "\n" +
                "Trail SL  : " + str.tostring(math.round(trail_sl_new, 2), "#.##") + "  (best + ATR x" + str.tostring(i_tr_dist) + " = +" + str.tostring(math.round(atr * i_tr_dist, 2), "#.##") + ")\n" +
                "Prev SL   : " + str.tostring(math.round(sl_price, 2), "#.##") + "  |  Target: " + str.tostring(math.round(tp_price, 2), "#.##") + "\n" +
                "Runup     : +" + str.tostring(math.round(_runup, 2), "#.##") + " (" + str.tostring(math.round(_runup / entry_p * 100, 2), "#.##") + "%)\n" +
                "Time      : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
                alert.freq_once_per_bar_close)
        sl_price := trail_sl_new
    strategy.exit("Short Exit", "Short", stop=sl_price, limit=tp_price)

// ── Exit detection (closed-trade alerts) ──────────────────────────────────────
var int _prev_closed = 0
if strategy.closedtrades > _prev_closed
    _i   = strategy.closedtrades - 1
    _ep  = strategy.closedtrades.entry_price(_i)
    _xp  = strategy.closedtrades.exit_price(_i)
    _pnl = strategy.closedtrades.profit(_i)
    _com = strategy.closedtrades.commission(_i)
    _sz  = math.abs(strategy.closedtrades.size(_i))
    _mr  = strategy.closedtrades.max_runup(_i)
    _bh  = strategy.closedtrades.exit_bar_index(_i) - strategy.closedtrades.entry_bar_index(_i)
    _dir = strategy.closedtrades.size(_i) > 0 ? "LONG" : "SHORT"
    _res = _pnl >= 0 ? "WIN" : "LOSS"
    _mv  = strategy.closedtrades.size(_i) > 0 ? (_xp - _ep) / _ep * 100 : (_ep - _xp) / _ep * 100
    _tot = strategy.closedtrades
    _wr  = _tot == 0 ? "--" : str.tostring(math.round(strategy.wintrades / _tot * 100, 1)) + "%"
    alert(
        "APM v3.1 | " + _dir + " EXIT [" + _res + "] | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
        "Entry   : " + str.tostring(math.round(_ep, 2), "#.##") + "  ->  Exit: " + str.tostring(math.round(_xp, 2), "#.##") + "\n" +
        "Move    : " + (_mv >= 0 ? "+" : "") + str.tostring(math.round(_mv, 2), "#.##") + "%\n" +
        "P&L     : " + (_pnl >= 0 ? "+" : "") + str.tostring(math.round(_pnl, 2), "#.##") + " USD\n" +
        "Comm    : -" + str.tostring(math.round(_com, 2), "#.##") + " USD\n" +
        "Max runup: " + str.tostring(math.round(_mr, 2), "#.##") + "\n" +
        "Bars    : " + str.tostring(_bh) + "\n" +
        "Equity  : $" + str.tostring(math.round(strategy.equity, 2), "#.##") + "\n" +
        "Trades  : " + str.tostring(_tot) + "  |  Win rate: " + _wr + "\n" +
        "Time    : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
        alert.freq_once_per_bar_close)
    _prev_closed := strategy.closedtrades

// ── Panic regime alerts ────────────────────────────────────────────────────────
if is_panic and not is_panic[1]
    alert(
        "APM v3.1 | PANIC REGIME STARTED | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
        "ATR     : " + str.tostring(math.round(atr, 2), "#.##") + "  |  ATR baseline: " + str.tostring(math.round(atr_bl, 2), "#.##") + "\n" +
        "Ratio   : " + str.tostring(math.round(atr / atr_bl, 2), "#.##") + "x  [threshold: " + str.tostring(i_panic_mult) + "x]\n" +
        "Status  : New entries SUSPENDED\n" +
        "Time    : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
        alert.freq_once_per_bar_close)

if not is_panic and is_panic[1]
    alert(
        "APM v3.1 | PANIC REGIME CLEARED | " + syminfo.ticker + " [" + timeframe.period + "]\n" +
        "ATR     : " + str.tostring(math.round(atr, 2), "#.##") + "  |  ATR baseline: " + str.tostring(math.round(atr_bl, 2), "#.##") + "\n" +
        "Ratio   : " + str.tostring(math.round(atr / atr_bl, 2), "#.##") + "x  [threshold: " + str.tostring(i_panic_mult) + "x]\n" +
        "Status  : New entries RESUMED\n" +
        "Time    : " + str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone),
        alert.freq_once_per_bar_close)

// ── Plots ─────────────────────────────────────────────────────────────────────
plot(i_show_emas ? ema_fast : na, "EMA 21",  color=color.new(#5b9ef4, 0),  linewidth=1)
plot(i_show_emas ? ema_mid  : na, "EMA 50",  color=color.new(#f6ad55, 0),  linewidth=1)
plot(i_show_emas ? ema_slow : na, "EMA 200", color=color.new(#f6e05e, 0),  linewidth=2)

// Stop / TP lines while in trade
p_sl = plot(strategy.position_size != 0 ? sl_price : na, "Stop",    color=color.new(color.red,   0), linewidth=1, style=plot.style_linebr)
p_tp = plot(strategy.position_size != 0 ? tp_price : na, "Target",  color=color.new(color.lime,  0), linewidth=1, style=plot.style_linebr)

// Entry markers
plotshape(long_ok,  title="Long entry",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.small)
plotshape(short_ok, title="Short entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,  0), size=size.small)

// Background: panic suppression active
bgcolor(is_panic ? color.new(color.red, 90) : na, title="Panic zone")

// ── Dashboard colours (top-level constants) ───────────────────────────────────
var color D_HDR = color.new(#1a1a2e,  5)
var color D_BG  = color.new(#0d0d1a, 15)
var color D_BRT = color.new(#e2e8f0,  0)
var color D_DIM = color.new(#718096,  0)
var color D_GRN = color.new(#48bb78,  0)
var color D_RED = color.new(#fc8181,  0)
var color D_YEL = color.new(#f6e05e,  0)
var color D_ORG = color.new(#f6ad55,  0)
var color D_BLU = color.new(#63b3ed,  0)

// ── Dashboard row helper (top-level function) ─────────────────────────────────
_row(tbl, r, lbl, val, vc) =>
    table.cell(tbl, 0, r, lbl, text_color=D_DIM, bgcolor=D_BG, text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, r, val, text_color=vc,    bgcolor=D_BG, text_size=size.small, text_halign=text.align_right)

// ── Dashboard ─────────────────────────────────────────────────────────────────
if i_show_dash and barstate.islast
    tbl_pos = switch i_dash_pos
        "Top Right"    => position.top_right
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        "Bottom Left"  => position.bottom_left
        "Middle Right" => position.middle_right
        "Middle Left"  => position.middle_left
        => position.top_right

    tbl = table.new(tbl_pos, columns=2, rows=20,
         border_width=1, border_color=color.new(color.gray, 60),
         frame_width=1,  frame_color=color.new(color.gray, 40))

    // header
    table.cell(tbl, 0, 0, "APM v3.1", text_color=D_BRT, bgcolor=D_HDR, text_size=size.normal, text_halign=text.align_left)
    table.cell(tbl, 1, 0, timeframe.period + " | " + syminfo.ticker, text_color=D_YEL, bgcolor=D_HDR, text_size=size.small, text_halign=text.align_right)

    // position
    pos_size = strategy.position_size
    _row(tbl, 1, "Position", pos_size > 0 ? "LONG" : pos_size < 0 ? "SHORT" : "FLAT", pos_size > 0 ? D_GRN : pos_size < 0 ? D_RED : D_DIM)
    _row(tbl, 2, "Entry",    pos_size == 0 ? "--" : str.tostring(strategy.position_avg_price, "#.##"), D_BRT)
    _row(tbl, 3, "Stop",     na(sl_price) or pos_size == 0 ? "--" : str.tostring(sl_price, "#.##"), D_RED)
    _row(tbl, 4, "Target",   na(tp_price) or pos_size == 0 ? "--" : str.tostring(tp_price, "#.##"), D_GRN)

    upnl     = pos_size == 0 ? 0.0 : (close - strategy.position_avg_price) * math.abs(pos_size) * (pos_size > 0 ? 1 : -1)
    upnl_str = pos_size == 0 ? "--" : (upnl >= 0 ? "+" : "") + str.tostring(upnl, "#.##")
    _row(tbl, 5, "Unrealised P&L", upnl_str, upnl >= 0 ? D_GRN : D_RED)

    // indicators section header
    table.cell(tbl, 0, 6, "Indicators", text_color=D_DIM, bgcolor=D_BG, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 6, "",           text_color=D_DIM, bgcolor=D_BG)

    _row(tbl,  7, "ADX",    str.tostring(adx, "#.#") + (is_trending ? " ok" : " --"), is_trending ? D_GRN : D_RED)
    _row(tbl,  8, "RSI",    str.tostring(rsi, "#.#"),  rsi > 70 ? D_RED : rsi < 30 ? D_GRN : D_BRT)
    _row(tbl,  9, "ATR",    str.tostring(atr, "#.##"), D_BLU)
    _row(tbl, 10, "Vol/MA", str.tostring(volume / vol_ma, "#.##") + "x", volume >= vol_ma * i_vol_mult ? D_GRN : D_DIM)

    // filters section header
    table.cell(tbl, 0, 11, "Filters", text_color=D_DIM, bgcolor=D_BG, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 11, "",        text_color=D_DIM, bgcolor=D_BG)

    _row(tbl, 12, "Trend", is_trending ? "PASS" : "FAIL", is_trending ? D_GRN : D_RED)
    _row(tbl, 13, "Panic", is_panic    ? "ACTIVE" : "OK", is_panic    ? D_YEL : D_GRN)

    macro_bull = close > ema_slow and ema_fast > ema_mid
    macro_bear = close < ema_slow and ema_fast < ema_mid
    _row(tbl, 14, "Macro bias", macro_bull ? "Bullish" : macro_bear ? "Bearish" : "Neutral", macro_bull ? D_GRN : macro_bear ? D_RED : D_ORG)

    // performance section header
    table.cell(tbl, 0, 15, "Performance", text_color=D_DIM, bgcolor=D_BG, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 15, "",            text_color=D_DIM, bgcolor=D_BG)

    total_trades = strategy.wintrades + strategy.losstrades
    wr_str = total_trades == 0 ? "--" : str.tostring(math.round(strategy.wintrades / total_trades * 100, 1)) + "%"
    pf_raw = strategy.grossloss == 0 ? na : strategy.grossprofit / math.abs(strategy.grossloss)

    _row(tbl, 16, "Net P&L",      (strategy.netprofit >= 0 ? "+" : "") + str.tostring(strategy.netprofit, "#.##"), strategy.netprofit >= 0 ? D_GRN : D_RED)
    _row(tbl, 17, "Win rate",     wr_str + " (" + str.tostring(strategy.wintrades) + "/" + str.tostring(total_trades) + ")", D_BRT)
    _row(tbl, 18, "Prof. factor", na(pf_raw) ? "--" : str.tostring(pf_raw, "#.##"), na(pf_raw) ? D_DIM : pf_raw >= 1.0 ? D_GRN : D_RED)
    _row(tbl, 19, "Max DD",       str.tostring(math.round(strategy.max_drawdown_percent, 2)) + "%", D_RED)

