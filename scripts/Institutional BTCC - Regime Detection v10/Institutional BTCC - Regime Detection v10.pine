//@version=6
strategy("Institutional BTCC - Regime Detection v11", overlay=true, initial_capital=10000, commission_value=0.06)

// ==========================================
// 1. INDICATOR SETUP
// ==========================================
ema200 = ta.ema(close, 200) 
[macdLine, signalLine, macdHist] = ta.macd(close, 12, 26, 9)
[bbMiddle, bbUpper, bbLower] = ta.bb(close, 20, 2)
volSMA = ta.sma(volume, 20)

// MACD histogram acceleration (momentum is building, not fading)
histAccelUp = (macdHist > 0) and (macdHist > macdHist[1])
histAccelDn = (macdHist < 0) and (macdHist < macdHist[1])

// ==========================================
// 2. MARKET REGIME DETECTION (The Key to Surviving 2026)
// ==========================================
// A. Trend Strength (ADX)
[diplus, diminus, adx] = ta.dmi(14, 14)
isTrending = adx > 30 // v11: raised from 25 — demand a genuinely strong trend
isChoppy = adx < 20   // Identifies sideways, trap-heavy markets

// B. Volatility State (ATR)
atr14 = ta.atr(14)
atr60 = ta.sma(atr14, 60)
// If short-term volatility is 40% higher than the baseline, we are in a panic/crash regime
isPanicVolatility = atr14 > (atr60 * 1.4) 

// ==========================================
// 3. RISK MANAGEMENT
// ==========================================
riskPerTrade = 0.01 
atrMultiplier = 1.5  // v11: tighter stop (was 3.0) → smaller max loss, better R:R
tpMultiplier  = 3.0  // v11: hard TP at ATR×3 = 2:1 R:R on the ATR×1.5 stop
stopDist = atr14 * atrMultiplier
capitalAtRisk = strategy.equity * riskPerTrade
posSize = stopDist > 0 ? capitalAtRisk / stopDist : 0

// ==========================================
// 4. REGIME-FILTERED PROTOCOLS (v11)
// ==========================================
// v11 tightened filters:
//   • volume ≥ 1.5× VolSMA  (was 1.0×)  — demand real participation
//   • close > BB band + ATR×0.3          — avoid thin/marginal breakouts
//   • MACD histogram accelerating in trade direction

// LONG: Macro Bullish + Strong Breakout + Strong Volume + MACD Accel + Trend + No Panic
longCondition = (close > ema200) and (macdLine > signalLine) and (close > bbUpper + atr14 * 0.3) and (volume > volSMA * 1.5) and isTrending and histAccelUp and not isPanicVolatility

// SHORT: Macro Bearish + Strong Breakdown + Strong Volume + MACD Accel + Trend + No Panic
shortCondition = (close < ema200) and (macdLine < signalLine) and (close < bbLower - atr14 * 0.3) and (volume > volSMA * 1.5) and isTrending and histAccelDn and not isPanicVolatility

// ==========================================
// 5. EXECUTION — HARD TP (2:1) + TRAILING STOP (v11)
// ==========================================
// Hard TP at 2:1 R:R enforces a minimum reward on every winning trade.
// Trailing stop activates once price moves ATR×1.5 in favor.
longSL      = close - stopDist
shortSL     = close + stopDist
longTP      = close + atr14 * tpMultiplier
shortTP     = close - atr14 * tpMultiplier
trailOffset = stopDist / syminfo.mintick

if (longCondition and strategy.opentrades == 0)
    strategy.entry("Long Trend", strategy.long, qty=posSize)
    strategy.exit("Exit Long", "Long Trend", stop=longSL, limit=longTP, trail_points=trailOffset, trail_offset=trailOffset)

if (shortCondition and strategy.opentrades == 0)
    strategy.entry("Short Trend", strategy.short, qty=posSize)
    strategy.exit("Exit Short", "Short Trend", stop=shortSL, limit=shortTP, trail_points=trailOffset, trail_offset=trailOffset)

// ==========================================
// 6. VISUALIZATION
// ==========================================
plot(ema200, color=color.new(color.white, 0), title="EMA 200", linewidth=2) 
// Visual warning: Background turns red when market is in panic volatility (Do Not Trade Zone)
bgcolor(isPanicVolatility ? color.new(color.red, 90) : na, title="Panic Volatility Warning")