# ─────────────────────────────────────────────────────────────────────────────
# APM Dashboard — Alpaca credentials template
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Active mode — controls which credentials fetch_chart_data.py uses.
# Values: paper | live   (default: paper)
ALPACA_MODE=paper

# Backtrader
DATA_SOURCE=alpaca  # Options: yfinance | alpaca
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets/v2

# ── Paper Trading ─────────────────────────────────────────────────────────────
# Generate at: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=

# ── Live Trading ──────────────────────────────────────────────────────────────
# Generate at: https://app.alpaca.markets → Live Trading → API Keys
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# ── Legacy (backward compat — used if _PAPER/_LIVE vars above are absent) ─────
ALPACA_API_KEY=PKA6JVXS7FYDSO7RWFUCLBVZPD
ALPACA_API_SECRET=J285cmRTWHuGgRKCVke297s4ouGDazGydFft3RADbZV7
ALPACA_SECRET_KEY=J285cmRTWHuGgRKCVke297s4ouGDazGydFft3RADbZV7
