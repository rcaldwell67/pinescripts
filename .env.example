# ─────────────────────────────────────────────────────────────────────────────
# APM Dashboard — Alpaca credentials template
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Active mode — controls which credentials fetch_chart_data.py uses.
# Values: paper | live   (default: paper)
ALPACA_MODE=paper

# ── Paper Trading ─────────────────────────────────────────────────────────────
# Generate at: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_PAPER_API_KEY=PKNIYXYVLHKHF43IIEUQIA42DJ
ALPACA_PAPER_API_SECRET=9djPy47EmNvMr6Yyfa3UpQ49ruQRWAmTmu8thmDvm34u

# ── Live Trading ──────────────────────────────────────────────────────────────
# Generate at: https://app.alpaca.markets → Live Trading → API Keys
ALPACA_LIVE_API_KEY=AKxxxxxxxxxxxxxxxxxxxxxx
ALPACA_LIVE_API_SECRET=9djPy47EmNvMr6Yyfa3UpQ49ruQRWAmTmu8thmDvm34u

# ── Legacy (backward compat — used if _PAPER/_LIVE vars above are absent) ─────
ALPACA_API_KEY=PKNIYXYVLHKHF43IIEUQIA42DJ
