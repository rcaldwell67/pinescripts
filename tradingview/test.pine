//@version=6
strategy("Crypto Momentum Trend", shorttitle="CMT", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// --- Inputs ---
fast_length = input.int(12, title="Fast EMA Length", minval=1)
slow_length = input.int(26, title="Slow EMA Length", minval=1)
src = input.source(close, title="Source")

// --- Calculations ---
fast_ma = ta.ema(src, fast_length)
slow_ma = ta.ema(src, slow_length)

// --- Plotting ---
plot(fast_ma, color=color.rgb(41, 98, 255), title="Fast EMA", linewidth=2)
plot(slow_ma, color=color.rgb(255, 109, 0), title="Slow EMA", linewidth=2)

// --- Conditions ---
long_cond = ta.crossover(fast_ma, slow_ma)
short_cond = ta.crossunder(fast_ma, slow_ma)

// --- Execution ---
if long_cond
    strategy.entry("Long", strategy.long)

if short_cond
    strategy.close("Long")
    // Uncomment the line below if you want the bot to also short
    // strategy.entry("Short", strategy.short)