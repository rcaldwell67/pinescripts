//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Adaptive Pullback Momentum v4.6
// 30min (CLM-optimised)
// THESIS
//   Most breakout strategies enter *after* the move is mature.  This strategy
//   enters during brief pullbacks to a key moving average while the broader
//   trend is intact, giving tighter natural stops and a higher-quality R:R.
//
// ENTRY LOGIC
//   Long  : EMA21 > EMA50 > EMA200 (full stack — stricter structure)
//            EMA21 rising ≥ 0.10%/3bars (slope-magnitude filter)
//            RSI rising on entry bar (momentum confirmation)
//            prev-bar low tagged EMA21 zone, current bar recovers above EMA21
//            + RSI 38–68  |  Volume ≥ 1.0× VolSMA  |  ADX > 10  |  no panic
//            + body ≥ 0.50×ATR  |  ATR ≥ 0.10% of price  |  no loss cooldown
//   Short : mirror of the above
//
// EXIT LOGIC
//   → Hard stop  : entry ± ATR × 1.5
//   → Hard TP    : entry ± ATR × 16.0 (trail does exit work; TP is safety net)
//   → Trail      : activates once price moves ATR×3.0 in favour,
//                  then trails ATR×0.1 from best price (maximum profit lock)
//   → Sizing     : 1 % of equity risked per trade
//
// v4.1 CHANGES vs v4.0  (CLM 30m sweep: +9.48% PF=2.297 vs +2.53% PF=1.112 baseline)
//   EMA condition : loose (close>EMA200 & EMA21>EMA50) → full stack EMA21>EMA50>EMA200
//   EMA slope     : ADDED — EMA21 must trend in trade direction over 3 bars
//   RSI direction : ADDED — RSI must be rising (long) / falling (short) on entry
//   Volume mult   : 1.0× → 1.2×   (higher conviction threshold)
//   Body filter   : 0.15× → 0.20×ATR (stricter doji rejection)
//   ATR floor     : ADDED — ATR ≥ 0.20% of price (kills high-commission low-vol)
//   SL multiplier : 1.5× → 2.0×   (wider stop → smaller qty → less commission)
//   TP multiplier : 2.0× → 3.0×   (sweep-found optimal for v4.1 filter set)
//   Trail activate: 1.5× → 2.5×   (let price run before trailing kicks in)
//   Trail distance: 0.8× → 1.5×   (wider trail stops micro-spike exits)
//   Panic mult    : 1.5× → 1.3×   (exit volatile regimes more aggressively)
//
// v4.2 CHANGES vs v4.1  (CLM 30m isolation sweep: +10.41% PF=2.415 vs +9.48% PF=2.297)
//   TP multiplier : 3.0× → 3.5×   (DI alignment / strong-close / RSI-2bar filters
//                  each tested — all reduced PF and return, confirming v4.1 entry
//                  logic is already optimal for this instrument/timeframe.
//                  Sole improvement: TP×3.5 → +10.41% PF=2.415 WR=70% 20 trades)
//
// v4.3 CHANGES vs v4.2  (S7 trail-dist sweep: +23.71% PF=1.417 n=51 WR=47.1% MDD=-12.75%)
//   Trail distance : 1.5× → 0.3×   (CRITICAL — locks profit immediately on activation)
//   Trail activate : 2.5×  (unchanged — wait for meaningful runup before trailing)
//   TP multiplier  : 3.5× → 16.0×  (trail exits do the work; TP is safety net only)
//   SL multiplier  : 2.0× → 1.5×   (tighter stop, better R:R entry)
//   ADX threshold  : 25   → 10     (relax trend filter — more signals on CLM 30m)
//   Pullback tol.  : 0.15% → 0.50% (wider pullback zone increases trade frequency)
//   RSI min Long   : 42  → 38      (slightly wider RSI window for longs)
//   RSI min Short  : 32  → 30
//   RSI max Short  : 58  → 62      (aligned to sweep fixed values)
//   Min body       : 0.20× → 0.15× (less strict doji filter)
//   ATR floor      : 0.20% → 0.10% (aligned to sweep)
//   Panic mult     : 1.3× → 1.5×   (aligned to sweep fixed value)
//   Risk per trade : 1%   → 3%     (larger position size to reach +23.71%)
//   Longs+Shorts   : both enabled  (trade_mode=both best on CLM 30m)
//
// v4.4 CHANGES vs v4.3  (S8 max-profit sweep: +82.59% PF=2.027 n=60 WR=41.7% MDD=-13.05% Calmar=6.33)
//   SL multiplier  : 1.5× → 1.0×   (tighter stop → larger position size per $ risk)
//   Trail activate : 2.5× → 3.0×   (let price run 3×ATR before trail locks in)
//   Trail distance : 0.3× → 0.1×   (hardest possible profit lock on activation)
//   Volume mult    : 1.2× → 1.0×   (lower entry bar = more signals, n: 51→60)
//   Risk per trade : 3%   → 4%     (hits 5× leverage cap optimally; 5%/6% identical)
//
// v4.5 CHANGES vs v4.4  (S9 MDD-constrained: +18.14% PF=2.25 n=17 WR=47.1% MDD=-4.17% Calmar=4.35)
//   Risk per trade : 4%   → 1%     (below 5× leverage cap for most CLM ATR levels)
//   Circuit Breaker: ADDED — halt new entries when equity drops CB% below HWM;
//                    resume when equity recovers halfway back to HWM.
//                    Default: 4% trigger (MDD capped ≈ 4.17%, Calmar 4.35×)
//
// v4.6 CHANGES vs v4.5  (S14 WR sweep: +23.87% PF=2.88 n=21 WR=61.9% MDD=-2.65% Calmar=9.00)
//   SL multiplier  : 1.0× → 1.5×   (wider stop gives trades more room before SL fires)
//   Min body       : 0.15× → 0.50×ATR  (require strong entry candle; filters weak doji-like bars)
//   EMA slope min  : direction-only → 0.10%/3bars minimum magnitude (active trend confirmation)
//   Post-loss CD   : ADDED — 13-bar cooldown after each loss (prevents re-entering failed patterns)
//                    Combined effect: trades now span full year (no CB lockout); MDD halved vs v4.5
// ─────────────────────────────────────────────────────────────────────────────

strategy(
	title             = "Adaptive Pullback Momentum v4.6",
	shorttitle        = "APM v4.6",
	overlay           = true,
	pyramiding        = 0,
	initial_capital   = 10000,
	default_qty_type  = strategy.cash,
	default_qty_value = 10000,        // overridden by risk-based sizing below
	commission_type   = strategy.commission.percent,
	commission_value  = 0.06,
	slippage          = 1)

// ─── Inputs ────────────────────────────────────────────────────────────────

// ─── Inputs ────────────────────────────────────────────────────────────────
var G_TREND = "Trend Filters"
i_ema_fast   = input.int  (21,   "EMA Fast",            group=G_TREND, minval=5)
i_ema_mid    = input.int  (50,   "EMA Mid",             group=G_TREND, minval=10)
i_ema_slow   = input.int  (200,  "EMA Slow",            group=G_TREND, minval=50)
i_adx_thresh = input.int  (10,   "ADX threshold",       group=G_TREND, minval=5, maxval=60)
i_adx_len    = input.int  (14,   "ADX / DI length",     group=G_TREND, minval=5)
i_ema_slope_bars = input.int(3,  "EMA21 slope bars",    group=G_TREND, minval=1, maxval=10, tooltip="EMA21 must rise/fall at least i_ema_slope_min_pct over this many bars.")
i_ema_slope_min_pct = input.float(0.10, "EMA21 slope min (%/3bars)", group=G_TREND, minval=0.0, maxval=1.0, step=0.01, tooltip="Minimum EMA21 slope magnitude required for entry (in % over 3 bars)")
i_pb_pct     = input.float(0.50, "Pullback tolerance (%)", group=G_TREND, minval=0.05, maxval=3.0, step=0.05, tooltip="How close prev bar high/low must come to EMA21 to qualify as a pullback.")

var G_MOM = "Momentum & Volume"
i_rsi_len    = input.int  (14,   "RSI length",          group=G_MOM, minval=3)
i_rsi_lo_l   = input.int  (38,   "RSI min – Long",      group=G_MOM, minval=10, maxval=70)
i_rsi_hi_l   = input.int  (68,   "RSI max – Long",      group=G_MOM, minval=50, maxval=90)
i_rsi_lo_s   = input.int  (30,   "RSI min – Short",     group=G_MOM, minval=10, maxval=50)
i_rsi_hi_s   = input.int  (62,   "RSI max – Short",     group=G_MOM, minval=40, maxval=80)
i_vol_len    = input.int  (20,   "Volume SMA length",   group=G_MOM, minval=5)
i_vol_mult   = input.float(1.0,  "Volume multiplier",   group=G_MOM, minval=0.1, maxval=5.0, step=0.1)
i_min_body   = input.float(0.50, "Min body (x ATR)",    group=G_MOM, minval=0.0, maxval=2.0, step=0.05, tooltip="Entry bar |close-open|/ATR must exceed this. Filters doji candles.")

var G_VOL = "Volatility"
i_atr_len    = input.int  (14,   "ATR length",          group=G_VOL, minval=3)
i_atr_bl_len = input.int  (60,   "ATR baseline length", group=G_VOL, minval=10)
i_atr_floor  = input.float(0.10, "ATR floor (% of price)", group=G_VOL, minval=0.0, maxval=2.0, step=0.01, tooltip="ATR/price must exceed this %. Stage-2 (12mo sweep) winner: 0.1% — removes near-zero ATR bars where commission drag dominates.")
i_panic_mult = input.float(1.5,  "Panic suppression mult", group=G_VOL, minval=1.0, step=0.1, tooltip="ATR > ATR_baseline x this value => skip new entries.")

var G_SESS = "Session"
i_sess_on    = input.bool (true,  "Enable session filter",   group=G_SESS)
i_sess_start = input.int  (9,    "Session start (ET hour)", group=G_SESS, minval=0, maxval=23)
i_sess_end   = input.int  (14,   "Session end (ET hour)",   group=G_SESS, minval=0, maxval=23, tooltip="Entries blocked from this hour onward. Default 14 = 2:00 PM ET.")

var G_RISK = "Risk Management"
i_sl_mult    = input.float(1.5,  "Stop loss ATR mult",   group=G_RISK, minval=0.3, step=0.1)
i_tp_mult    = input.float(16.0, "Take profit ATR mult", group=G_RISK, minval=0.5, step=0.1)
i_trail_act  = input.float(3.0,  "Trail activate (ATR)", group=G_RISK, minval=0.5, step=0.1, tooltip="Trail activates after price moves this many ATR in favor.")
i_trail_dist = input.float(0.1,  "Trail distance (ATR)", group=G_RISK, minval=0.01, step=0.01, tooltip="Distance from best price for trailing stop.")
i_risk_pct   = input.float(1.0,  "Risk per trade (%)",   group=G_RISK, minval=0.1, maxval=10.0, step=0.1, tooltip="% of equity risked per trade.")
i_cb_pct     = input.float(4.0,  "Circuit breaker (%)",  group=G_RISK, minval=0.1, maxval=20.0, step=0.1, tooltip="Halt new entries if equity drops this % below HWM.")
i_cd_bars    = input.int  (13,   "Post-loss cooldown bars", group=G_RISK, minval=0, maxval=50, tooltip="Bars to wait after a loss before re-entering.")
