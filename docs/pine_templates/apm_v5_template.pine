//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Adaptive Pullback Momentum v5.3
// 1h CLM  |  Longs + Shorts
// THESIS
//   Most breakout strategies enter *after* the move is mature.  This strategy
//   enters during brief pullbacks to a key moving average while the broader
//   trend is intact, giving tighter natural stops and a higher-quality R:R.
//
// ENTRY LOGIC (v5.3 — longs + shorts)
//   Long  : close > EMA200  |  EMA21 > EMA34
//            prev-bar low tagged EMA21, current bar recovers above EMA21 (bullish body)
//            + RSI 40–70  |  Volume ≥ 1.2× VolSMA  |  ADX > 33  |  no panic
//            + body ≥ 0.05×ATR
//   Short : inverse of above
//
// EXIT LOGIC
//   → Hard stop  : entry ± ATR × 0.9   (tight stop → larger position for same 1% risk)
//   → Hard TP    : entry ± ATR × 10.0  (fallback only; trail is the primary exit)
//   → Trail      : activates once price moves ATR×2.0 in favour,
//                  then trails ATR×0.5 from best price (snappy lock-in)
//   → Sizing     : 1.25 % of equity risked per trade
//
// v5.3 CHANGES vs v5.2  (Stage-6 risk-scaling sweep, CLM 1h)
//   Risk per trade: 1.0% → 1.25%  (same 13-trade signal quality, larger positions)
//   All signal params unchanged from v5.2
//   Result        : +22.05%, WR=69.2%, 13T, MDD=-4.54%, Calmar=4.86
//
// v5.2 CHANGES vs v5.1  (Stage-5 next-bar trail sweep, CLM 1h)
//   Shorts re-enabled : both directions
//   SL multiplier : 1.5× → 0.9×   (tighter SL = larger position = more $ per win)
//   TP fallback   : 1.5× → 10.0×  (effectively off; trail is the primary exit)
//   Trail activate: 2.5× → 2.0×   (earlier kick-in captures full trend run)
//   Trail distance: 0.5× → 0.5×   (unchanged; snappy 0.5 ATR below best)
//   ADX threshold : 35   → 33     (slight relaxation; more trades)
//   PB tolerance  : 0.10%→ 0.20%  (matches backtest-optimal)
//   EMA mid       : 50   → 34     (deeper sweep optimal)
//   RSI length    : 14   → 20
//   Volume mult   : 1.5× → 1.2×
//   Min body      : 0.20×→ 0.05×
//   ATR floor     : 0.30%→ 0.00%  (no floor needed at 1h)
//   EMA slope     : removed (not beneficial at 1h)
//   Panic mult    : 1.5× → 1.4×
//   ATR baseline  : 60   → 50 bars
//   Result        : +17.38%, WR=69.2%, 13T, MDD=-3.64%, Calmar=4.77
// ─────────────────────────────────────────────────────────────────────────────

strategy(
	title             = "Adaptive Pullback Momentum v5.3",
	shorttitle        = "APM v5.3",
	overlay           = true,
	pyramiding        = 0,
	initial_capital   = 10000,
	default_qty_type  = strategy.cash,
	default_qty_value = 10000,        // overridden by risk-based sizing below
	commission_type   = strategy.commission.percent,
	commission_value  = 0.06,
	slippage          = 1)

// ─── Inputs ────────────────────────────────────────────────────────────────
var G_TREND = "Trend Filters"
i_ema_fast   = input.int  (21,   "EMA Fast",            group=G_TREND, minval=5)
i_ema_mid    = input.int  (34,   "EMA Mid",             group=G_TREND, minval=10)
i_ema_slow   = input.int  (200,  "EMA Slow",            group=G_TREND, minval=50)
i_adx_thresh = input.int  (33,   "ADX threshold",       group=G_TREND, minval=5,  maxval=60)
i_adx_len    = input.int  (14,   "ADX / DI length",     group=G_TREND, minval=5)
i_pb_pct     = input.float(0.20, "Pullback tolerance (%)", group=G_TREND, minval=0.05, maxval=3.0, step=0.05,
				 tooltip="How close the prev bar's low/high must come to EMA-fast to count as a pullback")
i_ema_slope  = input.bool (false, "EMA slope filter (3-bar)", group=G_TREND,
				 tooltip="Require EMA-fast to be rising (longs) / falling (shorts) over the last 3 bars")

var G_MOM = "Momentum & Volume"
i_rsi_len    = input.int  (20,   "RSI length",            group=G_MOM, minval=3)
i_rsi_lo_l   = input.int  (40,   "RSI min – Long",        group=G_MOM, minval=10, maxval=70)
i_rsi_hi_l   = input.int  (70,   "RSI max – Long",        group=G_MOM, minval=50, maxval=90)
i_rsi_lo_s   = input.int  (30,   "RSI min – Short",       group=G_MOM, minval=10, maxval=50)
i_rsi_hi_s   = input.int  (60,   "RSI max – Short",       group=G_MOM, minval=40, maxval=80)
i_vol_len    = input.int  (20,   "Volume SMA length",     group=G_MOM, minval=5)
i_vol_mult   = input.float(1.2,  "Volume multiplier",     group=G_MOM, minval=0.3, maxval=5.0, step=0.1)
i_min_body   = input.float(0.05, "Min body (×ATR)",        group=G_MOM, minval=0.0, maxval=2.0, step=0.05,
				 tooltip="Entry bar body (|close-open|/ATR) must exceed this — filters doji / indecision candles")

var G_VOL = "Volatility"
