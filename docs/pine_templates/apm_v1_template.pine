//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Adaptive Pullback Momentum v1.1 — 5m
// Timeframe : 5-minute  ·  Instrument : CLM (Cornerstone Strategic Investment Fund, Inc.)
// Exchange   : NYSE  ·  Type: Closed-End Fund (CEF)
//
// THESIS
//   Enter short during brief intraday pullbacks to EMA21 while the macro trend
//   is confirmed by a full bearish EMA stack (21 < 50 < 200), capturing
//   momentum resumption after the pullback with tight, ATR-scaled risk.
//   v1.1 relaxes the ADX threshold and widens the pullback tolerance to
//   increase signal count, with a wider TP and later trail activation.
//
// ENTRY LOGIC  (SHORTS ONLY by default — sub-15m longs historically low WR)
//   Short : Full bearish stack  EMA21 < EMA50 < EMA200
//            EMA21 falling over 3 bars (slope filter)
//            ADX > 15  (trend strength — relaxed from 18; captures more CLM setups)
//            RSI falling on entry bar  +  RSI in [30 – 58]
//            Close < close[5] (5-bar momentum confirms direction)
//            Prev bar high tagged EMA21 zone (±0.40%); current bar closes below with body
//            Volume ≥ 0.3 × VolSMA  |  Body ≥ 0.15 × ATR  |  ATR floor ≥ 0.1%
//            Session 09:00 – 14:00 ET  (NYSE open through midday)
//            No panic: ATR ≤ ATR - 60SMA × 1.5
//            Macro filter: OFF (sweep v1.1 — removed; didn't improve 12mo net)
//   Optional: ADX slope (0=off), DI spread (0=off) — sweep: not beneficial on CLM
//
// EXIT LOGIC  (v1.1 sweep-optimised on CLM 5m 12-month window via Alpaca)
//   → Hard SL    : entry + ATR × 4.0  (wider; low ATR on CLM means SL hits cleanly)
//   → Hard TP    : entry − ATR × 8.0  (raised from 6.0; gives trail more room)
//   → Trail      : activates at ATR × 3.5 runup (later lock-in to avoid early exit),
//                  trails ATR × 0.1 from best price (very tight — captures trail gains quickly)
//   → Max bars   : disabled (0)
//   → Sizing     : 2% of equity risked per trade (raised from 1%)
//
// SWEEP RESULTS v1.1 (12-month 2025-03-13→2026-03-11, 9,018 5m bars via Alpaca Delayed):
//   v1.0 params : 81T  WR=76.5%  PF=1.498  net=+11.62%  MaxDD=-2.32%  Calmar=5.005
//   v1.1 params : 29T  WR=79.3%  PF=2.802  net=+27.73%  MaxDD=-5.46%  Calmar=5.081
//   Key changes : ADX 18→15, PB 0.25%→0.40%, TP ×6→×8, Trail_act 2.5→3.5, Risk 1%→2%, Macro OFF
// ─────────────────────────────────────────────────────────────────────────────

	title             = "Adaptive Pullback Momentum v1.1 · 5m",
	shorttitle        = "APM v1.1 5m",
	overlay           = true,
	pyramiding        = 0,
	initial_capital   = 10000,
	default_qty_type  = strategy.cash,
	default_qty_value = 10000,        // overridden by risk-based sizing
	commission_type   = strategy.commission.percent,
	commission_value  = 0.06,
	slippage          = 1)
	shorttitle        = "APMv1.1-5m", // <= 10 chars for MCP

strategy(
	title           = "Adaptive Pullback Momentum v1.1 · 5m",
	shorttitle      = "APMv1.1-5m", // <= 10 chars for MCP
	overlay         = true,
	pyramiding      = 0,
	initial_capital = 10000,
	default_qty_type = strategy.cash,
	default_qty_value = 10000,        // overridden by risk-based sizing
	commission_type = strategy.commission.percent,
	commission_value = 0.06,
	slippage        = 1
)
// ─── Inputs ────────────────────────────────────────────────────────────────

var gTrend = "Trend Filters"
emaFastLength   = input.int  (21,   "EMA Fast Length",               group=gTrend, minval=5)
emaMidLength    = input.int  (50,   "EMA Mid Length",                group=gTrend, minval=10)
emaSlowLength   = input.int  (200,  "EMA Slow Length",               group=gTrend, minval=50)
adxThreshold    = input.int  (15,   "ADX Threshold",                 group=gTrend, minval=5, maxval=60)
adxLength       = input.int  (14,   "ADX / DI Length",               group=gTrend, minval=5)
adxSlopeBars    = input.int  (
	0,    "ADX Slope Bars (set to zero to disable)",
	group = gTrend, minval = 0, maxval = 20,
	tooltip = "ADX must be higher than the value adxSlopeBars bars ago. Set adxSlopeBars to zero to disable this filter. Stage-1 sweep showed this filter is not beneficial on CLM."
)
diSpreadValue   = input.float(
	0.0,  "DI Spread Value (set to zero to disable)",
	group = gTrend, minval = 0.0, step = 0.5,
	tooltip = "For shorts: DI- must exceed DI+ by this many points (diSpreadValue). Set diSpreadValue to zero to disable this filter. Stage-1 sweep showed DI spread hurts entries on CLM — keep at zero unless re-optimised."
)
pullbackTolerancePercent = input.float(
	0.40, "Pullback Tolerance (%)", group = gTrend, minval = 0.05, maxval = 3.0, step = 0.05,
	tooltip = "How close the previous bar high must come to EMA21 to qualify as a pullback."
)
momentumBars     = input.int  (
	5,    "Momentum Bars (set to zero to disable)", group = gTrend, minval = 0, maxval = 20,
	tooltip = "Close must be below close[momentumBars] for shorts (confirms directional pressure). Set momentumBars to zero to disable this filter."
)

var gMom = "Momentum & Volume"
iRsiLen    = input.int  (14,   "RSI length",             group=gMom, minval=3)
iRsiLoL    = input.int  (42,   "RSI min – Long",         group=gMom, minval=10, maxval=70)
iRsiHiL    = input.int  (68,   "RSI max – Long",         group=gMom, minval=50, maxval=90)
iRsiLoS    = input.int  (30,   "RSI min – Short",        group=gMom, minval=10, maxval=50)
iRsiHiS    = input.int  (58,   "RSI max – Short",        group=gMom, minval=40, maxval=80)
iVolLen    = input.int  (20,   "Volume SMA length",      group=gMom, minval=5)
iVolMult   = input.float(0.3,  "Volume multiplier",      group=gMom, minval=0.1, maxval=5.0, step=0.1)
iMinBody   = input.float(
	0.15, "Min body (x ATR)", group = gMom, minval = 0.0, maxval = 2.0, step = 0.05,
	tooltip = "Entry bar |close-open|/ATR must exceed this. Filters doji candles."
)

var gVol = "Volatility"
iAtrLen    = input.int  (14,   "ATR length",              group=gVol, minval=3)
iAtrBlLen  = input.int  (60,   "ATR baseline length",     group=gVol, minval=10)
iAtrFloor  = input.float(
	0.1,  "ATR floor (% of price)", group = gVol, minval = 0.0, maxval = 2.0, step = 0.01,
	tooltip = "ATR/price must exceed this %. Stage-2 (12mo sweep) winner: 0.1% — removes near-zero ATR bars where commission drag dominates."
)
iPanicMult = input.float(
	1.5,  "Panic suppression mult", group = gVol, minval = 1.0, step = 0.1,
	tooltip = "ATR > ATR_baseline x this value => skip new entries."
)

var gSess = "Session"
iSessOn    = input.bool (true,  "Enable session filter",   group=gSess)
iSessStart = input.int  (9,    "Session start (ET hour)", group=gSess, minval=0, maxval=23)
iSessEnd   = input.int  (
	14,   "Session end (ET hour)", group = gSess, minval = 0, maxval = 23,
	tooltip = "Entries blocked from this hour onward. Default 14 = 2:00 PM ET."
)

var gRisk = "Risk Management"
iSlMult    = input.float(4.0,  "Stop loss ATR mult",       group=gRisk, minval=0.3, step=0.1)
iTpMult    = input.float(8.0,  "Take profit ATR mult",     group=gRisk, minval=0.5, step=0.1)
