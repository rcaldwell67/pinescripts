//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Adaptive Pullback Momentum v6.0
// 1D Look Back
// THESIS
//   Most breakout strategies enter *after* the move is mature.  This strategy
//   enters during brief pullbacks to a key moving average while the broader
//   trend is intact, giving tighter natural stops and a higher-quality R:R.
//
// ENTRY LOGIC
//   Long  : close > EMA200  |  EMA21 > EMA50  |  prev-bar low tagged EMA21
//            then current bar recovers above EMA21 (bullish body)
//            + RSI 42–72  |  Volume ≥ 1× VolSMA  |  ADX > 28  |  no panic
//            + body ≥ 0.30×ATR (entry bar must have meaningful directional close)
//   Short : mirror of the above (close < EMA200, EMA21 < EMA50, etc.)
//
// EXIT LOGIC
//   → Hard stop  : entry ± ATR × 2.0
//   → Hard TP    : entry ± ATR × 1.0  (1:2 inverse R:R — viable because WR=88.5%)
//   → Trail      : activates once price moves ATR×2.0 in favour,
//                  then trails ATR×0.4 from best price (wide trail suits daily bars)
//   → Sizing     : 1 % of equity risked per trade
//
// v6.1 CHANGES vs v6.0  (based on CLM 1D backtest sweep, 2014-2026)
//   ADX threshold : 25    → 28     (tighter trend filter; fewer but higher-quality trades)
//   RSI max Long  : 68    → 72     (wider RSI window captures more valid daily setups)
//   Min body      : 0.15× → 0.30×  (strong daily candles only; rejects weak signals)
//   Panic mult    : 1.5×  → 2.0×   (daily ATR spikes are structurally larger; needs headroom)
//   Stop loss     : 1.5×  → 2.0×   (wider stop accommodates daily bar noise)
//   Take profit   : 2.0×  → 1.0×   (key 1D insight: TP×2.0 never reached in 11 yrs; tight TP wins)
//   Trail activate: 1.5×  → 2.0×   (let daily winners breathe longer before trailing)
//   Trail distance: 0.8×  → 0.4×   (once trailing, ATR×0.4 is sufficient on 1D)
//   Directions    : both   (longs & shorts viable at 1D — WR 87.5% / 90.0% respectively)
//   EMA slope     : NOT added (slope filter hurts on slow-moving daily EMAs)
//   ATR floor     : NOT added (daily ATR is inherently meaningful; no floor needed)
//   Result        : CLM 1D 2014-2026 | +10.31% | PF=8.978 | WR=88.5% | 26 trades | MaxDD=-1.02%
//
// CLM 1D sweep-optimised defaults (sweep_fast.py, 1728 combos, full history 2002-2026):
//   EMA Mid       : 50    → 34     (slightly faster mid-trend reference)
//   Stop loss     : 2.0×  → 1.0×   (tighter stop → better R:R)
//   Take profit   : 1.0×  → 3.0×   (3:1 R:R replaces 0.5:1; largest single improvement)
//   Trail activate: 2.0×  → 99.0×  (trail effectively disabled; daily bars don't need it)
//   Min body      : 0.30× → 0.15×  (more relaxed; daily candle body filter less critical)
//   Pullback tol  : 0.15% → 0.10%  (tighter pullback for cleaner entries)
//   Directions    : both   → LONG ONLY (shorts net-negative on daily CLM)
//   RSI max Long  : 72    → 70
//   Result (best, 7 trades) : CLM 1D full history | PF=3.60 | net=+9.06% | WR=57.1% | MaxDD=-1.11%
//   Alt-1 (27 trades)      : AT=20, PB=0.25, TP=2.5, SL=1.5 | PF=2.08 | net=+14.6% | MaxDD=-4.62%
//
// v6.2 Stage-3 sweep (sweep_stage3.py, 14,580 combos — best by Calmar=6.046):
//   PB=0.30 | TP=3.0 | SL=1.5 | MaxB=25 | RSI L:42-75 | MB=0.20 | VO=1.0
//   Result (30 trades): PF=2.60 | net=+21.8% | WR=63.3% | MaxDD=-3.61% | Calmar=6.05
//   Key insight: MaxB=25 converts the 2021 stalled trade (27 bars, reversed before TP)
//   into a profitable exit, yielding a $267 swing on that single trade.
//
// v6.3 Stage-4 sweep (sweep_stage4.py, 720 combos — best by Calmar=7.308):
//   em_slope=8 (EMA_MID(34) rising vs 8 bars ago) | TP=3.5
//   Result (28 trades): PF=3.076 | net=+26.35% | WR=64.3% | MaxDD=-3.60% | Calmar=7.308
//   Key insight: EMA_MID slope filter removes 2 choppy-trend entries; TP=3.5 captures larger moves.
// ─────────────────────────────────────────────────────────────────────────────

strategy(
	title             = "Adaptive Pullback Momentum v6.1",
	shorttitle        = "APM v6.1",
	overlay           = true,
	pyramiding        = 0,
	initial_capital   = 10000,
	default_qty_type  = strategy.cash,
	default_qty_value = 10000,        // overridden by risk-based sizing below
	commission_type   = strategy.commission.percent,
	commission_value  = 0.06,
	slippage          = 1)

// ─── Inputs ────────────────────────────────────────────────────────────────
var G_TREND = "Trend Filters"
i_ema_fast   = input.int  (21,   "EMA Fast",            group=G_TREND, minval=5)
