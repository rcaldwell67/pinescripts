//@version=6

// ─────────────────────────────────────────────────────────────────────────────
// Universal Adaptive Pullback Momentum (APM-U)
// Combines best systematic filters and logic from v1–v6 for all active crypto symbols
//
// ENTRY LOGIC (Long/Short)
//   - EMA stack: EMA21 > EMA50 > EMA200 (long), EMA21 < EMA50 < EMA200 (short)
//   - EMA21 slope filter (optional, configurable)
//   - RSI momentum confirmation (rising for long, falling for short)
//   - Pullback: prev-bar low/high tags EMA21, current bar recovers/breaks
//   - RSI, Volume, ADX, ATR, and body filters (configurable)
//   - Panic regime filter (ATR spike suppression)
//   - Session filter (configurable)
//
// EXIT LOGIC
//   - Hard stop: entry ± ATR × SL multiplier
//   - Hard TP: entry ± ATR × TP multiplier
//   - Trailing stop: activates after price moves ATR × trail_activate, then trails ATR × trail_dist
//   - Max bars in trade (optional)
//   - Risk per trade configurable
//
// All parameters are inputs for flexibility across symbols/timeframes

strategy("Universal Adaptive Pullback Momentum", shorttitle="APM-U", overlay=true, pyramiding=0, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000, commission_type=strategy.commission.percent, commission_value=0.06, slippage=1)

// ─── Inputs ────────────────────────────────────────────────────────────────
var G_TREND = "Trend Filters"
i_ema_fast   = input.int  (21,   "EMA Fast",            group=G_TREND, minval=5)
i_ema_mid    = input.int  (50,   "EMA Mid",             group=G_TREND, minval=10)
i_ema_slow   = input.int  (200,  "EMA Slow",            group=G_TREND, minval=50)
i_adx_thresh = input.int  (20,   "ADX threshold",       group=G_TREND, minval=5, maxval=60)
i_adx_len    = input.int  (14,   "ADX / DI length",     group=G_TREND, minval=5)
i_pb_pct     = input.float(0.20, "Pullback tolerance (%)", group=G_TREND, minval=0.05, maxval=3.0, step=0.05)
i_ema_slope  = input.bool (true, "Enable EMA21 slope filter", group=G_TREND)
i_ema_slope_len = input.int(3, "EMA21 slope bars", group=G_TREND, minval=1)
i_ema_slope_min = input.float(0.0, "EMA21 min slope (%)", group=G_TREND, minval=0.0, maxval=1.0, step=0.01)

var G_MOM = "Momentum & Volume"
i_rsi_len    = input.int  (14,   "RSI length",          group=G_MOM, minval=3)
i_rsi_lo_l   = input.int  (42,   "RSI min – Long",      group=G_MOM, minval=10, maxval=70)
i_rsi_hi_l   = input.int  (72,   "RSI max – Long",      group=G_MOM, minval=50, maxval=90)
i_rsi_lo_s   = input.int  (32,   "RSI min – Short",     group=G_MOM, minval=10, maxval=50)
i_rsi_hi_s   = input.int  (58,   "RSI max – Short",     group=G_MOM, minval=40, maxval=80)
i_vol_len    = input.int  (20,   "Volume SMA length",   group=G_MOM, minval=5)
i_vol_mult   = input.float(1.2,  "Volume multiplier",   group=G_MOM, minval=0.1, maxval=5.0, step=0.1)
i_min_body   = input.float(0.20, "Min body (x ATR)",    group=G_MOM, minval=0.0, maxval=2.0, step=0.05)

var G_VOL = "Volatility"
i_atr_len    = input.int  (14,   "ATR length",          group=G_VOL, minval=3)
i_atr_bl_len = input.int  (60,   "ATR baseline length", group=G_VOL, minval=10)
i_atr_floor  = input.float(0.10, "ATR floor (% of price)", group=G_VOL, minval=0.0, maxval=2.0, step=0.01)
i_panic_mult = input.float(1.5,  "Panic suppression mult", group=G_VOL, minval=1.0, step=0.1)

var G_SESS = "Session"
i_sess_on    = input.bool (true,  "Enable session filter",   group=G_SESS)
i_sess_start = input.int  (9,    "Session start (ET hour)", group=G_SESS, minval=0, maxval=23)
i_sess_end   = input.int  (14,   "Session end (ET hour)",   group=G_SESS, minval=0, maxval=23)

var G_RISK = "Risk Management"
i_sl_mult    = input.float(2.0,  "Stop loss ATR mult",   group=G_RISK, minval=0.3, step=0.1)
i_tp_mult    = input.float(3.0,  "Take profit ATR mult", group=G_RISK, minval=0.5, step=0.1)
i_trail_act  = input.float(2.0,  "Trail activate (ATR)", group=G_RISK, minval=0.5, step=0.1)
i_trail_dist = input.float(0.5,  "Trail distance (ATR)", group=G_RISK, minval=0.01, step=0.01)
i_risk_pct   = input.float(1.0,  "Risk per trade (%)",   group=G_RISK, minval=0.1, maxval=10.0, step=0.1)

i_max_bars   = input.int  (25,   "Max bars in trade",    group=G_RISK, minval=1, maxval=100)

// ─── Indicator Calculations ────────────────────────────────────────────────
ema_fast = ta.ema(close, i_ema_fast)
ema_mid  = ta.ema(close, i_ema_mid)
ema_slow = ta.ema(close, i_ema_slow)
adx      = ta.adx(i_adx_len)
rsi      = ta.rsi(close, i_rsi_len)
vol_sma  = ta.sma(volume, i_vol_len)
atr      = ta.atr(i_atr_len)
atr_bl   = ta.sma(atr, i_atr_bl_len)

// ─── Trend Filters ────────────────────────────────────────────────────────
trend_long  = ema_fast > ema_mid and ema_mid > ema_slow
trend_short = ema_fast < ema_mid and ema_mid < ema_slow
ema21_slope = (ema_fast - ema_fast[i_ema_slope_len]) / ema_fast[i_ema_slope_len] * 100
ema21_slope_ok_long  = not i_ema_slope or ema21_slope > i_ema_slope_min
ema21_slope_ok_short = not i_ema_slope or ema21_slope < -i_ema_slope_min

// ─── Momentum & Volume Filters ────────────────────────────────────────────
rsi_long_ok  = rsi > i_rsi_lo_l and rsi < i_rsi_hi_l and rsi > rsi[1]
rsi_short_ok = rsi > i_rsi_lo_s and rsi < i_rsi_hi_s and rsi < rsi[1]
vol_ok       = volume > vol_sma * i_vol_mult
body         = math.abs(close - open)
body_ok      = body > atr * i_min_body

// ─── Volatility & Panic Filters ───────────────────────────────────────────
atr_ok   = atr / close > i_atr_floor / 100
panic_ok = atr < atr_bl * i_panic_mult

// ─── Session Filter ──────────────────────────────────────────────────────
sess_ok = true
if i_sess_on
	sess_ok := (hour >= i_sess_start and hour < i_sess_end)

// ─── Pullback Logic ──────────────────────────────────────────────────────
pb_long  = low[1] <= ema_fast[1] * (1 + i_pb_pct / 100) and close > ema_fast
pb_short = high[1] >= ema_fast[1] * (1 - i_pb_pct / 100) and close < ema_fast

// ─── Entry Conditions ────────────────────────────────────────────────────
long_cond = trend_long and ema21_slope_ok_long and rsi_long_ok and vol_ok and body_ok and atr_ok and panic_ok and sess_ok and pb_long
short_cond = trend_short and ema21_slope_ok_short and rsi_short_ok and vol_ok and body_ok and atr_ok and panic_ok and sess_ok and pb_short

// ─── Position Sizing ─────────────────────────────────────────────────────
capital = strategy.equity
risk_per_trade = i_risk_pct / 100 * capital
qty = risk_per_trade / (atr * i_sl_mult)

// ─── Entries ─────────────────────────────────────────────────────────────
if long_cond
	strategy.entry("Long", strategy.long, qty)
if short_cond
	strategy.entry("Short", strategy.short, qty)

// ─── Exits ───────────────────────────────────────────────────────────────
strategy.exit("TP/SL Long", from_entry="Long", stop=close - atr * i_sl_mult, limit=close + atr * i_tp_mult, trail_points=atr * i_trail_dist, trail_offset=atr * i_trail_act, max_bars_back=i_max_bars)
strategy.exit("TP/SL Short", from_entry="Short", stop=close + atr * i_sl_mult, limit=close - atr * i_tp_mult, trail_points=atr * i_trail_dist, trail_offset=atr * i_trail_act, max_bars_back=i_max_bars)
